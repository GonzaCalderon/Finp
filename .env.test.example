# Variables de entorno para el entorno de TEST
# Copiá este archivo a .env.test.local y completá los valores reales.
# .env.test.local NO debe comitearse (ya está en .gitignore)

# ─── Base de datos de TEST ────────────────────────────────────────────────────
# Usá una DB separada para test para no contaminar datos reales
MONGODB_URI=mongodb://localhost:27017/finp-test

# ─── NextAuth ─────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=un-secreto-largo-para-test-local
NEXTAUTH_URL=http://localhost:3000

# ─── Usuario de test (E2E) ────────────────────────────────────────────────────
# Este usuario debe existir en la DB de test antes de correr los E2E.
# Ver tests/e2e/helpers/README.md para instrucciones de creación.
TEST_USER_EMAIL=test@finp.dev
TEST_USER_PASSWORD=TestPass123!

# ─── Playwright ───────────────────────────────────────────────────────────────
# URL base de la app cuando se corre en modo CI (con servidor ya levantado)
PLAYWRIGHT_BASE_URL=http://localhost:3000
